############################################################
# 🔧 Application Settings
############################################################
# Environment type: development, staging, production
APP_ENV=production
# KEY PROFILE: production (Supabase/PostgreSQL)
ENV_KEY=production

# Application name
APP_NAME=DOLE-GIP System

# Application URL (adjust if using localhost or domain)
APP_URL=https://dole-system.vercel.app

# Authentication (Vite-exposed)
VITE_AUTH_USERNAME=your_username
VITE_AUTH_PASSWORD=your_password
VITE_USE_SUPABASE=true
VITE_DEBUG=false

############################################################
# 📌 Application Version
############################################################
APP_VERSION=6.7.0

############################################################
# 🗄️ Database Configuration (Supabase PostgreSQL)
############################################################
# Database connection type
DB_CONNECTION=pgsql
USE_SUPABASE=true

# Host
DB_HOST=db.llnddycvbcetztzwbdpx.supabase.co

# Port
DB_PORT=5432

# Database name
DB_DATABASE=postgres

# Database username
DB_USERNAME=postgres

# Database password
DB_PASSWORD=your_supabase_db_password

# [SUPABASE] Note: Supabase requires SSL (db_sslmode=require)

############################################################
# 🔑 API Keys & Tokens
############################################################
# Example: third-party API keys
API_KEY_GOOGLE=
API_KEY_OPENAI=
API_KEY_STRIPE=

# JWT or session secret for authentication
JWT_SECRET=your-secret-key-here-change-in-production

############################################################
# 📧 Mail Server Settings
############################################################
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@dole.gov.ph
MAIL_FROM_NAME="DOLE-GIP System"

############################################################
# 🌐 CORS / Security
############################################################
# Allowed origins for cross-origin requests
# Dynamic detection for 192.168.x.x is enabled in 'development' mode
CORS_ALLOWED_ORIGINS=https://dole-system.vercel.app,http://localhost,http://127.0.0.1

# FormSubmit Configuration
FORMSUBMIT_EMAIL=markjordanugtong.202200752@email.com

############################################################
# ⚙️ Miscellaneous
############################################################
# Logging level: debug, info, warning, error
LOG_LEVEL=debug
DEBUG_MODE=false

# Timezone (Philippines)
APP_TIMEZONE=Asia/Manila
TZ=Asia/Manila
