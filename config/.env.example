############################################################
# 🔧 Application Settings
############################################################
# Environment type: development, staging, production
APP_ENV=development

# Application name
APP_NAME=DOLE-GIP System

# Application URL (adjust if using localhost or domain)
APP_URL=http://localhost

# Authentication (Vite-exposed)
VITE_AUTH_USERNAME=your_username
VITE_AUTH_PASSWORD=your_password

############################################################
# 🗄️ Database Configuration (XAMPP/Laragon MySQL)
############################################################
# Database connection type
DB_CONNECTION=mysql

# Host (default is localhost or 127.0.0.1)
DB_HOST=127.0.0.1

# Port (default MySQL port)
DB_PORT=3306

# Database name
DB_DATABASE=dole_db

# Database username (default is 'root')
DB_USERNAME=root

# Database password (leave blank if root has no password)
DB_PASSWORD=

############################################################
# 🔑 API Keys & Tokens
############################################################
# Example: third-party API keys
API_KEY_GOOGLE=
API_KEY_OPENAI=
API_KEY_STRIPE=

# JWT or session secret for authentication
JWT_SECRET=your-secret-key-here-change-in-production

############################################################
# 📧 Mail Server Settings
############################################################
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@dole.gov.ph
MAIL_FROM_NAME="DOLE-GIP System"

############################################################
# 🌐 CORS / Security
############################################################
# Allowed origins for cross-origin requests
# Dynamic detection for 192.168.x.x is enabled in 'development' mode
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# FormSubmit Configuration
FORMSUBMIT_EMAIL=markjordanugtong.202200752@email.com

############################################################
# ⚙️ Miscellaneous
############################################################
# Logging level: debug, info, warning, error
LOG_LEVEL=debug

# Timezone (Philippines)
APP_TIMEZONE=Asia/Manila
TZ=Asia/Manila
