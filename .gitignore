# Environment Configuration — DO NOT commit local .env at root
# config/.env is committed so Vercel can read DB credentials
# To protect secrets in production, set them in Vercel Dashboard > Settings > Environment Variables instead
.env
config/.env

# Database Backups
*.sql.backup
*.sql.bak

# IDE and Editor Files
.vscode/
.idea/
*.swp
*.swo
*~

# OS Files
.DS_Store
Thumbs.db
desktop.ini

# Node Modules
node_modules/
npm-debug.log
yarn-error.log

# Build Output — dist/ is committed so Vercel can serve pre-built Vite assets
# (Vercel does not run `npm run build` unless you configure a build command)
build/
.cache/

# Logs
*.log
logs/
*.md

# Temporary Files
tmp/
temp/
*.tmp

# PHP
vendor/
composer.lock

# XAMPP Specific
xampp/
htdocs/phpmyadmin/