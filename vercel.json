{
    "version": 2,
    "functions": {
        "api/**/*.php": {
            "runtime": "vercel-php@0.7.2"
        }
    },
    "routes": [
        {
            "handle": "filesystem"
        },
        {
            "src": "/api/(auth|beneficiaries|logs|notifications|profile)",
            "dest": "/api/$1.php"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
