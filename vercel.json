{
    "version": 2,
    "functions": {
        "api/**/*.php": { "runtime": "vercel-php@0.7.4" }
    },
    "routes": [
        { "handle": "filesystem" },
        {
            "src": "/api/(.*)",
            "dest": "/api/$1.php"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
