{
    "version": 2,
    "functions": {
        "**/*.php": {
            "runtime": "vercel-php@0.7.5"
        }
    },
    "routes": [
        {
            "handle": "filesystem"
        },
        {
            "src": "/api/(auth|beneficiaries|logs|notifications|profile)",
            "dest": "/api/$1.php"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
