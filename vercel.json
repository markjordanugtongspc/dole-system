{
    "version": 2,
    "functions": {
        "api/index.php":        { "runtime": "vercel-php@0.7.4" },
        "api/auth.php":         { "runtime": "vercel-php@0.7.4" },
        "api/beneficiaries.php":{ "runtime": "vercel-php@0.7.4" },
        "api/logs.php":         { "runtime": "vercel-php@0.7.4" },
        "api/notifications.php":{ "runtime": "vercel-php@0.7.4" },
        "api/profile.php":      { "runtime": "vercel-php@0.7.4" },
        "api/check_duplicate.php":{ "runtime": "vercel-php@0.7.4" }
    },
    "routes": [
        { "handle": "filesystem" },
        {
            "src": "/api/auth",
            "dest": "/api/auth.php"
        },
        {
            "src": "/api/beneficiaries(.*)",
            "dest": "/api/beneficiaries.php"
        },
        {
            "src": "/api/logs(.*)",
            "dest": "/api/logs.php"
        },
        {
            "src": "/api/notifications(.*)",
            "dest": "/api/notifications.php"
        },
        {
            "src": "/api/profile(.*)",
            "dest": "/api/profile.php"
        },
        {
            "src": "/api/check_duplicate(.*)",
            "dest": "/api/check_duplicate.php"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
